# Anthropic API（問題文の生成に使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs API（音声読み上げに使用）
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# 本番で使う声のVoice ID（「声くらべ」で決めたものをここに設定）
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# 読み上げモデル
#   eleven_v3              … 2025年6月以降、日本語品質が大きく向上した最新モデル（推奨）
#   eleven_multilingual_v2 … 安定志向。淡々とした読み上げはこちらが合う場合も
# お話の記憶では誤読が命取りなので、両方を「声くらべ」で比較して決めるのがおすすめ
ELEVENLABS_MODEL=eleven_v3

# ─────────────────────────────────────────────
# 「声くらべ」モードで横並び比較する候補リスト（カンマ区切り）
# 形式: 表示名:VoiceID   ※表示名は自由
# 帰宅後、ElevenLabsのVoice Libraryで「Japanese」「narration」等で探した
# 気になる声のVoice IDをここに足して、同じお話で一括比較できます。
COMPARE_VOICES=Rachel:21m00Tcm4TlvDq8ikWAM,Charlotte:XB0fDUnXU5powFXDhCwa,Matilda:XrExE9yKIg1WjnnlVkGX

# 声くらべで両モデルを比較したい場合のモデルリスト（カンマ区切り）
COMPARE_MODELS=eleven_v3,eleven_multilingual_v2

# ─────────────────────────────────────────────
# ネット公開（Render等）時のパスワード保護
#   APP_PASSWORD を設定すると、サイトを開く時にユーザー名/パスワードを要求します。
#   空のままだとローカル利用とみなして認証なし（PC内だけなら不要）。
#   ※クラウド公開時は必ず APP_PASSWORD を設定すること（クレジット悪用防止）。
APP_USERNAME=ohanashi
APP_PASSWORD=
